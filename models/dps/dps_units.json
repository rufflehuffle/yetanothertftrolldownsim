{
  "_schema": {
    "cost": "gold cost",
    "role": "sim role key — 'caster' (7 mana/auto + 2 mana/s regen, 1s cast time) or 'marksman' (10 mana/auto, no regen, 0s cast time). Attack/Magic prefix is flavour only; no effect on simulation.",
    "atk_dmg": "[1★, 2★, 3★] physical attack damage",
    "atk_spd": "attacks per second (constant across stars)",
    "starting_mana": "flat value",
    "mana_cost": "flat value",
    "ability.cast_time": "seconds locked out of attacking while casting (1 for casters, 0 for marksmen)",
    "ability.auto_magic_dmg": "[1★, 2★, 3★] magic damage per auto attack (passive bomb/replacement — added on top of physical auto)",
    "ability.auto_magic_targets": "number of targets hit by magic auto (default 1)",
    "ability.hits[].magic_dmg": "[1★, 2★, 3★] magic damage per instance",
    "ability.hits[].damage_type": "'magic' (default) | 'physical' | 'true'",
    "ability.hits[].targets": "number of targets hit by this instance",
    "ability.hits[].per_second": "bool — magic_dmg is per second; multiply by duration for total",
    "ability.hits[].duration": "[1★, 2★, 3★] seconds (for DoTs)",
    "ability.hits[].note": "optional clarification",
    "ability.first_cast_hits": "hit array used only on the first cast (e.g. Annie's global DoT); subsequent casts use hits[]",
    "ability.subsequent_mana_cost": "mana cost applied after the first cast (e.g. Annie 160 → 20)"
  },

