{
  "_schema": {
    "structure": "{ TraitName: { breakpoint_or_unique: [ {metric, value, scope, notes?}, ... ] } }",
    "metric": "'tank_ehp_pct' | 'dps_pct'",
    "value": "fractional multiplier — applied as (1 + value) to the unit's base metric. E.g. 0.25 = +25%.",
    "scope": "'selfish' (trait members only) | 'splash' (all board units) | 'strongest_tank' | 'strongest_carry' | 'second_strongest_carry'",
    "notes": "optional — derivation, approximation method, or caveats",
    "empty_array": "breakpoint exists in-game but effect is unquantifiable or negligible in the board model"
  },

  "_conversion_factors": {
    "source": "tank_ehp/trait_ehp_multipliers.py + dps/trait_dps_multipliers.py  (2-star baseline)",
    "flat_hp_to_ehp_pct":         0.00044389,
    "flat_armor_mr_to_ehp_pct":   0.00556048,
    "health_regen_to_ehp_pct_per_s": 0.01109722,
    "as_pct_to_dps_pct":          0.00591229,
    "ap_pct_to_dps_pct":          0.00585748,
    "ad_pct_to_dps_pct":          0.00393726,
    "avg_auto_phys_frac":         0.2936,
    "direct_conversions": {
      "health_pct":      "tank_ehp_pct = value / 100  (1:1)",
      "damage_amp_pct":  "dps_pct = value / 100  (1:1)",
      "shield_pct_max_hp": "tank_ehp_pct = value / 100  (shield adds proportionally to HP before res_mult)",
      "durability_pct":  "tank_ehp_pct = 1/(1 - x) - 1  where x = DR fraction"
    },
    "crit_formula": "dps_pct = avg_auto_phys_frac × crit_chance/100 × (0.4 + crit_dmg_bonus/100)",
    "omnivamp_formula": "tank_ehp_pct ≈ omnivamp_pct × unit_dps × 25 × res_mult / base_ehp  (unit-specific; rough average used)"
  },

